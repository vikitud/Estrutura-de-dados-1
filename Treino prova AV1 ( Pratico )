🧱 PASSO 1 — Classe Cliente
class Cliente {
    String nome;

    public Cliente(String nome) {
        this.nome = nome;
    }
}

👉 Tradução:
“cria cliente com nome”

🧱 PASSO 2 — Classe Produto
class Produto {
    String nome;
    double preco;

    public Produto(String nome, double preco) {
        this.nome = nome;
        this.preco = preco;
    }
}
🧱 PASSO 3 — Classe Pedido
class Pedido {
    Cliente cliente;
    Produto produto;
    double total;

    public Pedido(Cliente cliente, Produto produto) {
        this.cliente = cliente;
        this.produto = produto;
        calcularTotal();
    }

    public void calcularTotal() {
        total = produto.preco;
    }

    public void mostrar() {
        System.out.println(cliente.nome);
        System.out.println(produto.nome);
        System.out.println(total);
    }
}
🧱 PASSO 4 — MAIN
public class Main {
    public static void main(String[] args) {

        Cliente c = new Cliente("João");
        Produto p = new Produto("Caderno", 10);

        Pedido ped = new Pedido(c, p);

        ped.mostrar();
    }
}
