#include <stdio.h> 

  // função recursiva para caulcular o fatoria lde um numero 
  long fatorial_recursivo(long n ){ 
// caso base: fatorial de 0 é 1
  if (n == 0){
    return 1;
  } else if (n < 0 ) { 
    // fatorial não esta definido para numeros negativos 
  printf("Erro: fatorial  não esta definida para numeros negativos.\n");
  return -1; // returna -1 pra indicar um erro
  } else {
    //numero recursivo: n! = n * (n-1)!
    return  n * fatorial_recursivo(n-1);
  }
}

